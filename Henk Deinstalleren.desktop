[Desktop Entry]
Version=1.0
Type=Application
Name=Henk Deïnstalleren
Comment=Verwijder de live versie van Henk (code blijft bewaard)
Exec=bash -lc 'cd "$(dirname "%k")" && bash deinstalleer.sh; read -rp "Druk op Enter om te sluiten..."'
Path=
Terminal=true
Icon=system-software-uninstall
Categories=Utility;
StartupNotify=false
